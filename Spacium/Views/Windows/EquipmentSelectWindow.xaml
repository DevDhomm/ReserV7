<Window
  x:Class="Spacium.Views.Windows.EquipmentSelectWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Ajouter Équipement"
  Width="500"
  Height="600"
  WindowStartupLocation="CenterOwner"
  ShowInTaskbar="False"
  ResizeMode="NoResize"
>
  <Grid Background="{DynamicResource ControlBackgroundBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="20,20,20,0" Orientation="Vertical">
      <TextBlock FontSize="18" FontWeight="Bold" Text="Ajouter un Équipement" />
      <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,8,0,0" Text="Sélectionnez un équipement existant ou créez-en un nouveau" TextWrapping="Wrap" />
    </StackPanel>

    <!-- Content -->
    <TabControl x:Name="TabControl" Grid.Row="1" Margin="20,16,20,0">
      <!-- Tab 1: Select Existing -->
      <TabItem Header="Sélectionner un existant">
        <Grid Background="{DynamicResource ControlBackgroundBrush}">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <!-- Search -->
          <TextBox
            x:Name="SearchBox"
            Grid.Row="0"
            Margin="12,12,12,8"
            Padding="8"
            Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
          />

          <!-- Equipment List -->
          <ListBox
            x:Name="EquipmentList"
            Grid.Row="1"
            Margin="12,0,12,12"
            ItemsSource="{Binding FilteredEquipment}"
            SelectedItem="{Binding SelectedExistingEquipment, Mode=TwoWay}"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
          >
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Padding="8" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="0,0,0,1">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Vertical">
                      <TextBlock FontWeight="Bold" Text="{Binding Nom}" />
                      <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding Type, StringFormat='Type: {0}'}" />
                      <TextBlock FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="{Binding Description}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="12,0,0,0">
                      <TextBlock FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding EstFonctionnel, StringFormat='État: {0}'}" TextAlignment="Right" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </TabItem>

      <!-- Tab 2: Create New -->
      <TabItem Header="Créer un nouveau">
        <Grid Background="{DynamicResource ControlBackgroundBrush}" Margin="12">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <!-- Equipment Name -->
          <TextBlock Grid.Row="0" FontWeight="Bold" Text="Nom de l'équipement *" Margin="0,0,0,4" />
          <TextBox
            x:Name="NewEquipmentName"
            Grid.Row="1"
            Margin="0,0,0,12"
            Padding="8"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
          />

          <!-- Equipment Type -->
          <TextBlock Grid.Row="2" FontWeight="Bold" Text="Type d'équipement *" Margin="0,0,0,4" />
          <TextBox
            x:Name="NewEquipmentType"
            Grid.Row="3"
            Margin="0,0,0,12"
            Padding="8"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
          />

          <!-- Equipment Description -->
          <TextBlock Grid.Row="4" FontWeight="Bold" Text="Description" Margin="0,0,0,4" VerticalAlignment="Top" />
          <TextBox
            x:Name="NewEquipmentDescription"
            Grid.Row="5"
            Margin="0,0,0,0"
            Padding="8"
            TextWrapping="Wrap"
            AcceptsReturn="True"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            VerticalAlignment="Stretch"
          />
        </Grid>
      </TabItem>
    </TabControl>

    <!-- Buttons -->
    <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Margin="20" VerticalAlignment="Center">
      <Button
        x:Name="CancelButton"
        Margin="0,0,12,0"
        Padding="20,8,20,8"
        Content="Annuler"
        Background="{DynamicResource ControlFillColorDefaultBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        Click="CancelButton_Click"
      />
      <Button
        x:Name="AddButton"
        Padding="20,8,20,8"
        Content="Ajouter"
        Background="CadetBlue"
        Foreground="White"
        Click="AddButton_Click"
      />
    </StackPanel>
  </Grid>
</Window>
