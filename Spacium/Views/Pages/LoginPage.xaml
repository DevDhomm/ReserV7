<Page
  x:Class="Spacium.Views.Pages.LoginPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:Spacium.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="LoginPage"
  d:DataContext="{d:DesignInstance local:LoginPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="450"
  d:DesignWidth="1000"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  Background="{DynamicResource ApplicationBackgroundBrush}"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
>
    <Grid Margin="20">


        <Border
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="360"
            CornerRadius="16"
        >
            <Border.Effect>
                <DropShadowEffect
                    Color="#000000"
                    BlurRadius="20"
                    ShadowDepth="4"
                    Opacity="0.15"
                />
            </Border.Effect>

            <Border
                Padding="36,52"
                CornerRadius="16"
                Background="#FFFFFF"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="2"
            >
                <StackPanel TextOptions.TextFormattingMode="Display">
                    <TextBlock Text="Spacium - Connexion" FontSize="22" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="Nom d'utilisateur" FontSize="13" Foreground="#333333" />
                    <TextBox Text="{Binding ViewModel.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" Padding="10" />
                    <TextBlock Text="Mot de passe" FontSize="13" Foreground="#333333" Margin="0,8,0,0" />
                    <TextBox Text="{Binding ViewModel.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" Padding="10" />
                    <ui:Button Content="Se connecter" Command="{Binding ViewModel.LoginCommand}" Margin="0,16,0,0" HorizontalAlignment="Stretch" Appearance="Primary" />
                </StackPanel>
            </Border>

        </Border>
    </Grid>
</Page>
