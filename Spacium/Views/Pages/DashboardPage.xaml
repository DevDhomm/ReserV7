<Page
  x:Class="Spacium.Views.Pages.DashboardPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:Spacium.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="DashboardPage"
  d:DataContext="{d:DesignInstance local:DashboardPage,
                                     IsDesignTimeCreatable=False}"
  d:DesignHeight="450"
  d:DesignWidth="800"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
>
  <Page.Resources>
    <Style x:Key="DashboardListViewStyle" TargetType="ListView">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style x:Key="DashboardListViewItemStyle" TargetType="ListViewItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
  </Page.Resources>
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="14" Padding="24" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock FontSize="30" FontWeight="Bold" Text="Bienvenue sur Spacium" />
          <TextBlock Margin="0,8,0,0" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Vue d'ensemble des réservations et accès rapide aux actions principales." />
        </StackPanel>
        <Image Grid.Column="1" Source="pack://application:,,,/Assets/logo.png" Width="90" Height="76" Margin="16,0,0,0" />
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="0,16,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Margin="0,0,12,0" Padding="18" CornerRadius="12" Background="{DynamicResource ControlFillColorSecondaryBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
        <StackPanel>
          <TextBlock Text="Réservations du jour" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
          <TextBlock Text="{Binding ViewModel.TodayReservationsCount}" FontSize="30" FontWeight="SemiBold" Margin="0,6,0,0" />
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Margin="6,0" Padding="18" CornerRadius="12" Background="{DynamicResource ControlFillColorSecondaryBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
        <StackPanel>
          <TextBlock Text="Salles occupées maintenant" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
          <TextBlock Text="{Binding ViewModel.OccupiedRoomsCount}" FontSize="30" FontWeight="SemiBold" Margin="0,6,0,0" />
        </StackPanel>
      </Border>

      <Border Grid.Column="2" Margin="12,0,0,0" Padding="18" CornerRadius="12" Background="{DynamicResource ControlFillColorSecondaryBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
        <StackPanel>
          <TextBlock Text="Salles indisponibles" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
          <TextBlock Text="{Binding ViewModel.UnavailableRoomsCount}" FontSize="30" FontWeight="SemiBold" Margin="0,6,0,0" />
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="2" Margin="0,16,0,0" Padding="16" CornerRadius="12" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
      <StackPanel Orientation="Horizontal">
        <Button Command="{Binding ViewModel.GoToBookRoomCommand}" Content="Réserver" Padding="16,8" Background="{DynamicResource BrandPrimaryBrush}" Foreground="White" Margin="0,0,10,0" />
        <Button Command="{Binding ViewModel.GoToMyReservationsCommand}" Content="Mes réservations" Padding="16,8" BorderBrush="{DynamicResource BrandAccentBrush}" BorderThickness="1" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="3" Margin="0,16,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Margin="0,0,8,0" Padding="18" CornerRadius="12" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <TextBlock Text="Réservations en cours" FontSize="18" FontWeight="SemiBold" />

          <ListView Grid.Row="1" Margin="0,12,0,0" ItemsSource="{Binding ViewModel.OngoingReservations}" Style="{StaticResource DashboardListViewStyle}" ItemContainerStyle="{StaticResource DashboardListViewItemStyle}">
            <ListView.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,8" Padding="12" CornerRadius="8" Background="{DynamicResource ControlFillColorSecondaryBrush}" BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}" BorderThickness="1">
                  <WrapPanel>
                    <TextBlock Text="{Binding SalleNom}" FontWeight="SemiBold" FontSize="14" Margin="0,0,14,0" />
                    <TextBlock Text="{Binding Motif}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,1,14,0" />
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,14,0">
                      <Run Text="Utilisateur: " />
                      <Run Text="{Binding Utilisateur}" />
                    </TextBlock>
                    <TextBlock Text="{Binding DateDebut}" FontWeight="SemiBold" Margin="0,0,10,0" />
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                      <Run Text="{Binding HeureDebut}" />
                      <Run Text=" - " />
                      <Run Text="{Binding HeureFin}" />
                    </TextBlock>
                  </WrapPanel>
                </Border>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </Grid>
      </Border>

      <Border Grid.Column="1" Margin="8,0,0,0" Padding="18" CornerRadius="12" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <TextBlock Text="Prochaines réservations" FontSize="18" FontWeight="SemiBold" />

          <ListView Grid.Row="1" Margin="0,12,0,0" ItemsSource="{Binding ViewModel.UpcomingReservations}" Style="{StaticResource DashboardListViewStyle}" ItemContainerStyle="{StaticResource DashboardListViewItemStyle}">
            <ListView.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,8" Padding="12" CornerRadius="8" Background="{DynamicResource ControlFillColorSecondaryBrush}" BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}" BorderThickness="1">
                  <WrapPanel>
                    <TextBlock Text="{Binding SalleNom}" FontWeight="SemiBold" FontSize="14" Margin="0,0,14,0" />
                    <TextBlock Text="{Binding Motif}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,1,14,0" />
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,14,0">
                      <Run Text="Utilisateur: " />
                      <Run Text="{Binding Utilisateur}" />
                    </TextBlock>
                    <TextBlock Text="{Binding DateDebut}" FontWeight="SemiBold" Margin="0,0,10,0" />
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                      <Run Text="{Binding HeureDebut}" />
                      <Run Text=" - " />
                      <Run Text="{Binding HeureFin}" />
                    </TextBlock>
                  </WrapPanel>
                </Border>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Page>

